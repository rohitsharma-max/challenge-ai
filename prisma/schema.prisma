generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  emailVerified      Boolean    @default(true) @map("email_verified")
  emailOtpHash       String?    @map("email_otp_hash")
  emailOtpExpiresAt  DateTime?  @map("email_otp_expires_at")
  emailOtpRequestedAt DateTime? @map("email_otp_requested_at")
  resetPasswordOtpHash       String?    @map("reset_password_otp_hash")
  resetPasswordOtpExpiresAt  DateTime?  @map("reset_password_otp_expires_at")
  resetPasswordOtpRequestedAt DateTime? @map("reset_password_otp_requested_at")
  avatarUrl          String?    @map("avatar_url")
  passwordHash       String?    @map("password_hash")
  googleId           String?    @unique @map("google_id")
  authProvider       String     @default("email") @map("auth_provider")
  onboardingComplete Boolean    @default(false) @map("onboarding_complete")
  categories         String[]   @default([])
  difficulty         Difficulty @default(medium)
  allowOutdoor       Boolean    @default(true) @map("allow_outdoor")
  currentStreak      Int        @default(0) @map("current_streak")
  bestStreak         Int        @default(0) @map("best_streak")
  totalXp            Int        @default(0) @map("total_xp")
  lastRestoreDate    DateTime?  @map("last_restore_date") @db.Date
  theme              String     @default("dark")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  userChallenges UserChallenge[]
  streakRestores StreakRestore[]

  @@map("users")
}

model Challenge {
  id               String     @id @default(uuid())
  title            String
  description      String
  category         String
  difficulty       Difficulty
  isOutdoor        Boolean    @default(false) @map("is_outdoor")
  xpReward         Int        @map("xp_reward")
  estimatedMinutes Int        @default(30) @map("estimated_minutes")
  createdAt        DateTime   @default(now()) @map("created_at")

  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  challengeId       String?         @map("challenge_id")
  customTitle       String?         @map("custom_title")
  customDescription String?         @map("custom_description")
  challengeDate     DateTime        @map("challenge_date") @db.Date
  status            ChallengeStatus @default(pending)
  completedAt       DateTime?       @map("completed_at")
  proofImageUrl     String?         @map("proof_image_url")
  proofText         String?         @map("proof_text")
  xpEarned          Int             @default(0) @map("xp_earned")
  createdAt         DateTime        @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge? @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeDate])
  @@index([userId])
  @@index([challengeDate])
  @@map("user_challenges")
}

model StreakRestore {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  xpSpent      Int      @map("xp_spent")
  restoredDate DateTime @map("restored_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streak_restores")
}

enum Difficulty {
  easy
  medium
  hard
}

enum ChallengeStatus {
  pending
  completed
  missed
  restored
}
